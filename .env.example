# === Ollama ===
OLLAMA_HOST=http://localhost:11434

# === Dual-Model Architecture (optimized for RTX 4090 16GB) ===
# Generator: 14B coder for HTML generation (~8.5GB VRAM)
GENERATOR_MODEL=qwen2.5-coder:14b
# Router: 3B for classification, chat, summaries (~2GB VRAM)
ROUTER_MODEL=qwen2.5:3b

# === Model Parameters ===
GENERATOR_CTX_SIZE=8192
GENERATOR_TEMPERATURE=0.7
GENERATOR_MAX_TOKENS=6144
ROUTER_CTX_SIZE=2048
ROUTER_TEMPERATURE=0.1
ROUTER_MAX_TOKENS=512

# === Caching ===
CACHE_ENABLED=true
CACHE_MAX_SIZE_MB=500
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_TTL_HOURS=168

# === Application ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# === Scraper ===
TD_BASE_URL=https://www.td.com/ca/en/personal-banking
SCRAPE_DELAY_SECONDS=2
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080

# === Fine-Tuning (for cloud GPU) ===
BASE_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct
LORA_RANK=32
LORA_ALPHA=64
LEARNING_RATE=1e-4
NUM_EPOCHS=3
BATCH_SIZE=2
GRADIENT_ACCUMULATION=8
